.card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}
.card-media {
  aspect-ratio: 343/258;
  position: relative;
  width: 100%;
}
@supports not (aspect-ratio: 343/258) {
  .card-media {
    height: 516rpx;
  }
}
.card-media__cover {
  height: 100%;
  object-fit: cover;
  width: 100%;
}
.card-media__tags {
  column-gap: 8rpx;
  display: flex;
  left: 0;
  padding: 16rpx;
  position: absolute;
  right: 0;
  top: 0;
}
.card-media__tags .tag {
  align-items: center;
  border-radius: 8rpx;
  color: #fff;
  display: flex;
  font-size: 24rpx;
  line-height: 32rpx;
  padding: 4rpx 8rpx;
}
.card-media__tags .tag--primary {
  background-color: rgba(0, 0, 0, 0.75);
  color: #f0e7d4;
}
.card-media__tags .tag .icon {
  height: 24rpx;
  margin-right: 4rpx;
  width: 24rpx;
}
.card-content {
  font-size: 24rpx;
  line-height: 36rpx;
  padding: 24rpx;
}
.card-content .card-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 48rpx;
}
.card-content .card-subtitle {
  line-height: inherit;
  margin-top: 8rpx;
}
.card-content .card-desc {
  color: gray;
  line-height: inherit;
  margin-top: 16rpx;
}
.card-content .card-content__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}
.card-content .card-content__tags .tag {
  background-color: #eee;
  border-radius: 8rpx;
  color: gray;
  font-size: 24rpx;
  line-height: 32rpx;
  padding: 4rpx 8rpx;
}
.card-content .card-content__tags .tag .icon {
  height: 24rpx;
  margin-right: 4rpx;
  width: 24rpx;
}
.card-content .card-content__pf-tags {
  display: inline-table;
  gap: 8rpx;
  margin-top: 16rpx;
}
.card-content .card-content__pf-tags .tag {
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  background-color: #eee;
  border-radius: 8rpx;
  color: gray;
  display: -webkit-box;
  font-size: 24rpx;
  line-height: 32rpx;
  overflow: hidden;
  padding: 4rpx 8rpx;
  text-overflow: ellipsis;
  word-break: break-all;
}
.card-content .card-content__pf-tags .tag .icon {
  height: 24rpx;
  margin-right: 4rpx;
  width: 24rpx;
}
.card-content .card-price {
  align-items: baseline;
  color: gray;
  display: flex;
  line-height: inherit;
  margin-top: 32rpx;
}
.card-content .card-price__number {
  color: #000;
  font-family: Montserrat;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 52rpx;
  margin-right: 8rpx;
}
.card-content .card-price__number .symbol {
  display: inline-block;
  margin-right: 4rpx;
}
