  align-items: center;
  color: #666;
  display: flex;
  font-size: 28rpx;
  font-weight: lighter;
  font-weight: 400;
  height: 104rpx;
  justify-content: center;
  margin-bottom: 12rpx;
  position: relative;
  text-align: center;
  transition: color 0.2s;
