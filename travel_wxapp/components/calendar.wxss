.bottomDialogBoxCalendar .bottomDialogMask {
  background-color: rgba(0, 0, 0, 0.5);
  height: 100vh;
  left: 0;
  position: fixed;
  top: 0;
  width: 100vw;
  z-index: 100;
}
.bottomDialogBoxCalendar .bottomDialog {
  bottom: 0;
  height: auto;
  left: 0;
  position: fixed;
  width: 100%;
  z-index: 101;
}
.bottomDialogBoxCalendar .bottomDialog .title {
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  color: #000;
  font-size: 36rpx;
  font-weight: 600;
  height: 112rpx;
  line-height: 112rpx;
  position: relative;
  text-align: center;
}
.bottomDialogBoxCalendar .bottomDialog .title .iconfont {
  color: #000;
  font-size: 40rpx;
  left: 36rpx;
  line-height: 1;
  position: absolute !important;
  position: relative;
  top: 36rpx;
}
.bottomDialogBoxCalendar .bottomDialog .title .iconfont:after {
  bottom: -60rpx;
  content: "";
  left: -60rpx;
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  z-index: 9;
}
.bottomDialogBoxCalendar .bottomDialog .dialogBox {
  background-color: #f8f8f8;
  padding: 0 24rpx 24rpx;
}
.bottomDialogBoxCalendar .bottomDialog .dialogBox.calendarChoose {
  background: #fff;
  padding: 0;
}
.bottomDialogBoxCalendar
  .bottomDialog
  .dialogBox.calendarChoose
  .calendar
  .weeks {
  background: #f2f3f5;
  display: flex;
  padding: 0 12rpx;
}
.bottomDialogBoxCalendar
  .bottomDialog
  .dialogBox.calendarChoose
  .calendar
  .weeks
  .weekDay {
  color: gray;
  flex: 1;
  font-size: 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}
.bottomDialogBoxCalendar
  .bottomDialog
  .dialogBox.calendarChoose
  .calendar
  .weeks
  .weekDay.red {
  color: #a43127;
}
.bottomDialogBoxCalendar
  .bottomDialog
  .dialogBox.calendarChoose
  .calendar
  .monthBoxWrapper {
  background: #f2f3f5;
  max-height: 840rpx;
  overflow-y: scroll;
  padding: 0 12rpx;
}
.bottomDialogBoxCalendar
  .bottomDialog
  .dialogBox.calendarChoose
  .calendar
  .monthBox
  .monthTitle {
  border-bottom: 1px solid #f8f8f8;
  margin: 0-12rpx;
  padding-bottom: 10rpx;
  padding-left: 32rpx;
  padding-top: 10rpx;
}
.bottomDialogBoxCalendar
  .bottomDialog
  .dialogBox.calendarChoose
  .calendar
  .monthBox
