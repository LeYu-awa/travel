.ui_roomList .packageBox .packageTopTitle {
  color: #000;
  font-size: 24rpx;
  margin: 20rpx 0;
}
.ui_roomList .packageBox .theRoom {
  margin-bottom: 20rpx;
}
.ui_roomList .packageBox .seeMore {
  align-items: center;
  color: #000;
  display: flex;
  font-size: 28rpx;
  justify-content: center;
  padding: 32rpx;
  text-align: center;
}
.ui_roomList .room {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 32rpx;
  overflow: hidden;
}
.ui_roomList .room .logo {
  display: block;
  height: 516rpx;
  width: 100%;
}
.ui_roomList .room .roomTopBox {
  position: relative;
}
.ui_roomList .room .roomTopBox .roomPicCount {
  background: rgba(0, 0, 0, 0.6);
  border-radius: 18rpx;
  bottom: 24rpx;
  color: #fff;
  font-size: 20rpx;
  height: 36rpx;
  line-height: 36rpx;
  position: absolute;
  right: 24rpx;
  text-align: center;
  width: 54rpx;
}
.ui_roomList .room .roomTypeBox {
  padding: 24rpx;
}
.ui_roomList .room .roomTypeBox .roomTypeTitle {
  margin-bottom: 10rpx;
}
.ui_roomList .room .roomTypeBox .roomTypeTitle .roomName {
  color: #000;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}
.ui_roomList .room .roomTypeBox .roomTypeTitle .aboutDes {
  color: gray;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}
.ui_roomList .room .roomTypeBox .roomTypeTitle .aboutDes .aboutItem {
  margin-right: 6rpx;
}
.ui_roomList .room .roomTypeBox .theRoom {
  align-items: center;
  border-bottom: 1px solid #f8f8f8;
  display: flex;
  height: 128rpx;
  justify-content: space-between;
}
.ui_roomList .room .roomTypeBox .theRoom:last-of-type {
  margin-bottom: 0;
}
.ui_roomList .room .roomTypeBox .theRoom .leftPart {
  flex: 1;
}
.ui_roomList .room .roomTypeBox .theRoom .leftPart .roomTitleDesc {
  align-items: center;
  color: gray;
  display: flex;
  font-size: 24rpx;
  line-height: 24rpx;
  margin-bottom: 16rpx;
}
.ui_roomList .room .roomTypeBox .theRoom .leftPart .roomTitleDesc .iconfont {
  margin-right: 6rpx;
}
.ui_roomList .room .roomTypeBox .theRoom .leftPart .priceItem {
  color: gray;
  font-size: 24rpx;
}
.ui_roomList .room .roomTypeBox .theRoom .leftPart .priceItem .money {
  color: #000;
  font-family: Montserrat;
  font-size: 36rpx;
  font-weight: 600;
}
.ui_roomList .room .roomTypeBox .theRoom .leftPart .priceItem .money2 {
  background: rgba(219, 137, 0, 0.16);
  border-radius: 8rpx;
  color: #000;
  display: inline-block;
  font-family: Montserrat;
  font-size: 20rpx;
  margin-top: 8rpx;
  padding: 8rpx;
}
.ui_roomList .room .roomTypeBox .theRoom .rightPart .goBtn {
  background-color: #000;
  background-image: url(https://dsplatweb.oss-cn-chengdu.aliyuncs.com/songzan/images/btnBlack.png);
  background-repeat: repeat;
  background-size: 80rpx 75rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 32rpx;
  text-align: center;
}
.ui_roomList .room .roomTypeBox .theRoom .rightPart .goBtn.disabled {
  background: #eee;
  color: #ccc;
}
