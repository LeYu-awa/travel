.ui_dailyPrice .dailyPriceBox .monthList {
  align-items: center;
  border-bottom: 0.5px solid #eee;
  display: flex;
  height: 84rpx;
  margin: 0 32rpx;
}
.ui_dailyPrice .dailyPriceBox .monthList .monthItem {
  align-items: center;
  display: flex;
  flex-direction: column;
  height: 100%;
  justify-content: center;
  margin-right: 56rpx;
  position: relative;
}
.ui_dailyPrice .dailyPriceBox .monthList .monthItem.active .minPrice,
.ui_dailyPrice .dailyPriceBox .monthList .monthItem.active .timeTitle {
  color: #000;
  font-weight: 700;
}
.ui_dailyPrice .dailyPriceBox .monthList .monthItem.active:after {
  background: #a43127;
  bottom: -1px;
  content: "";
  height: 6rpx;
  left: 0;
  position: absolute;
  right: 0;
}
.ui_dailyPrice .dailyPriceBox .monthList .monthItem .timeTitle {
  color: #666;
  font-size: 28rpx;
}
.ui_dailyPrice .dailyPriceBox .monthList .monthItem .minPrice {
  color: #999;
  font-size: 24rpx;
  margin-top: 10rpx;
}
.ui_dailyPrice .dailyPriceBox .calendar .weeks {
  display: flex;
}
.ui_dailyPrice .dailyPriceBox .calendar .weeks .weekDay {
  color: #333;
  flex: 1;
  font-size: 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}
.ui_dailyPrice .dailyPriceBox .calendar .weeks .weekDay.weekend {
  color: #a43127;
}
.ui_dailyPrice .dailyPriceBox .calendar .monthBoxWrapper {
  max-height: 840rpx;
  overflow-y: scroll;
  padding: 0 10rpx 40rpx;
}
.ui_dailyPrice .dailyPriceBox .calendar .monthBox .monthDay {
  display: flex;
  flex-wrap: wrap;
}
.ui_dailyPrice .dailyPriceBox .calendar .monthBox .monthDay .day {
  align-items: center;
  color: #000;
  display: flex;
  flex-direction: column;
  font-size: 28rpx;
  height: 116rpx;
  justify-content: center;
  margin-top: 8rpx;
  position: relative;
  text-align: center;
  transition: color 0.2s;
  transition: all 0.5s;
  width: 14.285%;
}
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.unActive
  .currentDay,
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.unActive
  .currentPrice,
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.unActive
  .number {
  color: #ccc;
}
.ui_dailyPrice .dailyPriceBox .calendar .monthBox .monthDay .day.active {
  background: #a43127;
  border-radius: 10rpx;
}
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.active
  .currentDay,
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.active
  .currentPrice,
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.active
  .number {
  color: #fff;
}
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.active
  .currentPrice,
.ui_dailyPrice
  .dailyPriceBox
  .calendar
  .monthBox
  .monthDay
  .day.active
  .number {
  opacity: 0.7;
}
.ui_dailyPrice .dailyPriceBox .calendar .monthBox .monthDay .day .number {
  color: #000;
  font-size: 20rpx;
  line-height: 1;
}
.ui_dailyPrice .dailyPriceBox .calendar .monthBox .monthDay .day .currentDay {
  color: #000;
  font-size: 28rpx;
  line-height: 1;
  margin-top: 8rpx;
}
.ui_dailyPrice .dailyPriceBox .calendar .monthBox .monthDay .day .currentPrice {
  color: #000;
  font-size: 20rpx;
  line-height: 1;
  margin-top: 8rpx;
}
