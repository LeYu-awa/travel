.tabs_warp {
  width: 100%;
}
.tabs_warp .scroll-view {
  background: #fff;
  width: 100%;
}
.tabs_warp .scroll-view .scroll-div {
  display: flex;
  white-space: nowrap;
  width: 100%;
}
.tabs_warp .scroll-view .scroll-div .scroll-flex {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  margin-left: 40rpx;
}
.tabs_warp .scroll-view .scroll-div .scroll-flex .name {
  font-size: 32rpx;
  padding: 40rpx 0 28rpx;
}
.tabs_warp .scroll-view .scroll-div .scroll-flex .sc-name {
  font-weight: 600;
}
.tabs_warp .scroll-view .scroll-div .scroll-flex .scroll-top {
  background: #a33127;
  border-radius: 36rpx;
  height: 4rpx;
  width: 64rpx;
}
.tabs_warp.fixed {
  padding-bottom: 20rpx;
  position: fixed;
  z-index: 9;
}
.header {
  background-color: initial;
  height: 180rpx;
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 91111;
}
.header .header-img {
  font-size: 42rpx;
  height: 40rpx;
  left: 26rpx;
  line-height: 40rpx;
  position: absolute;
  top: 100rpx;
}
.header .header-img .header-flex {
  align-items: center;
  background-color: hsla(0, 0%, 80%, 0.8);
  border-radius: 64rpx;
  display: flex;
  height: 64rpx;
  justify-content: center;
  width: 64rpx;
}
.welcome {
  height: 490rpx;
  position: relative;
  width: 100%;
}
.welcome .wel-left {
  bottom: 60rpx;
  left: 40rpx;
  position: absolute;
}
.welcome .wel-left .wel-title {
  color: #fff;
  font-family: Source Han Serif CN;
  font-size: 56rpx;
  font-weight: 900;
}
.welcome .wel-left .wel-text {
  color: #fff;
  font-family: OPPOSans;
  font-size: 32rpx;
  font-weight: 400;
  line-height: 48rpx;
  margin-top: 30rpx;
  width: 630rpx;
}
.details {
  background-color: #fff;
  margin-top: 20rpx;
  width: 100%;
}
.details .details-edge {
  padding: 40rpx;
}
.details .details-edge .details-title {
  font-size: 36rpx;
  font-weight: 600;
}
.details .details-edge .map-container {
  border-radius: 12rpx;
  height: 516rpx;
  margin-top: 40rpx;
  overflow: hidden;
  width: 100%;
}
.details .details-edge .map {
  height: 100%;
  width: 100%;
}
.details .details-edge .more-bg {
  border: 1px solid #ccc;
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 500;
  height: 80rpx;
  line-height: 80rpx;
  margin: 40rpx auto auto;
  text-align: center;
  width: 304rpx;
}
.details .details-edge .details-bg {
  background-color: #f8f8f8;
  border-radius: 18rpx;
  margin-top: 40rpx;
  width: 100%;
}
.details .details-edge .details-bg .deta-marke {
  align-items: center;
  border-bottom: 1px solid #dfdfdf;
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  margin-left: 12rpx;
  padding: 26rpx 10rpx;
  width: 96%;
}
.details .details-edge .details-bg .deta-marke .mark-flex {
  align-items: center;
  display: flex;
}
.details .details-edge .details-bg .deta-marke .no-page {
  height: 240rpx;
  position: relative;
  width: 240rpx;
}
.details .details-edge .details-bg .deta-marke .no-page .no-video {
  align-items: center;
  background-color: hsla(0, 0%, 80%, 0.5);
  border-radius: 46rpx;
  color: #fff;
  display: flex;
  height: 46rpx;
  justify-content: center;
  position: absolute;
  right: 10rpx;
  top: 12rpx;
  width: 46rpx;
  z-index: 1;
}
.details .details-edge .details-bg .deta-marke .no-page .no-video .video-icon {
  font-size: 32rpx;
  margin-left: 4rpx;
  text-align: center;
}
.details .details-edge .details-bg .deta-marke .no-page .deta-image {
  border-radius: 16rpx;
  height: 240rpx;
  width: 240rpx;
}
.details .details-edge .details-bg .deta-marke .mark-title {
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  display: -webkit-box;
  font-size: 32rpx;
  font-weight: 500;
  margin-left: 14rpx;
  overflow: hidden;
}
.details .details-edge .movies-flex {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
}
.details .details-edge .movies-flex .moves-hote {
  align-items: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-top: 80rpx;
  width: 33%;
}
.details .details-edge .movies-flex .moves-hote .moves-image {
  border-radius: 12rpx;
  height: 270rpx;
  width: 180rpx;
}
.details .details-edge .movies-flex .moves-hote .moves-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 40rpx;
}
.details .details-edge .movies-flex .moves-hote .moves-type {
  color: gray;
  font-size: 24rpx;
  font-weight: 500;
  margin-top: 20rpx;
}
.details .details-edge .det-top {
  margin-top: -20rpx;
}
.details .details-edge .det-tips {
  font-family: OPPOSans;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 42rpx;
  margin-top: 34rpx;
  width: 100%;
}
.details .details-edge .weather {
  background: #fcf4e6;
  border-radius: 16rpx;
  box-shadow:
    0 20rpx 30rpx -6rpx rgba(0, 0, 0, 0.1),
    0 8rpx 12rpx -4rpx rgba(0, 0, 0, 0.05);
  margin-top: 22rpx;
  width: 100%;
}
.details .details-edge .weather .weather-situation {
  align-items: center;
  border-bottom: 1px solid #e9e2d5;
  display: flex;
  justify-content: space-between;
  margin-left: 26rpx;
  padding: 40rpx 0;
  width: 93%;
}
.details .details-edge .weather .weather-situation .weat-date {
  font-size: 28rpx;
  font-weight: 500;
  width: 30%;
}
.details .details-edge .weather .weather-situation .weat-lows {
  font-size: 28rpx;
  font-weight: 500;
  width: 15%;
}
.details .details-edge .weather .weather-situation .weat-humidity {
  font-size: 28rpx;
  font-weight: 500;
  width: 40%;
}
.details .details-edge .weather .weather-situation .weat-rays {
  color: gray;
  font-size: 24rpx;
  font-weight: 500;
  margin-top: 20rpx;
}
.details .details-edge .title-arrive {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 34rpx;
  padding-bottom: 20rpx;
}
.details .details-edge .details-altitude {
  align-items: center;
  display: flex;
}
.details .details-edge .details-altitude .det-name {
  border: 1px solid #ccc;
  border-right: none;
  height: 92rpx;
  line-height: 92rpx;
  padding-left: 24rpx;
  width: 65%;
}
.details .details-edge .details-altitude .det-altude {
  border: 1px solid #ccc;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  width: 35%;
}
.details .details-edge .details-altitude .bottomBtn {
  border-top: none;
}
.details .details-edge .details-route {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  height: 184rpx;
  margin-top: 28rpx;
  overflow-x: auto;
  padding-left: 40rpx;
}
.details .details-edge .details-route,
.details .details-edge .details-route .details-left {
  align-items: center;
  display: flex;
  width: 100%;
}
.details .details-edge .details-route .details-left .details-eg {
  align-items: center;
  display: flex;
  flex-direction: column;
}
.details
  .details-edge
  .details-route
  .details-left
  .details-eg
  .details-number {
  background-color: #000;
  border-radius: 40rpx;
  color: #fff;
  height: 40rpx;
  line-height: 40rpx;
  margin-top: 16rpx;
  text-align: center;
  width: 40rpx;
}
.details
  .details-edge
  .details-route
  .details-left
  .details-eg
  .det-startHotelName {
  font-family: OPPOSans;
  font-size: 28rpx;
  margin-top: 16rpx;
  white-space: nowrap;
}
.details .details-edge .details-route .details-left .details-eg .det-distance,
.details
  .details-edge
  .details-route
  .details-left
  .details-eg
  .det-startHotelAltitude {
  font-family: OPPOSans;
  font-size: 24rpx;
  margin-top: 16rpx;
  white-space: nowrap;
}
.details .details-edge .details-route .details-left .details-eg .det-useTime {
  font-family: OPPOSans;
  font-size: 24rpx;
  margin-top: 4rpx;
  white-space: nowrap;
}
.details .details-edge .details-route .details-left .det-iconfont {
  margin-left: 20rpx;
  padding-right: 20rpx;
}
.title-arrive {
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 34rpx;
  padding-bottom: 20rpx;
}
.customCallout {
  height: 90rpx;
  position: relative;
  width: 60rpx;
}
.customCallout .siteIndex {
  background: #fffded;
  border: 2rpx solid #222;
  border-radius: 50%;
  color: #222;
  font-size: 28rpx;
  font-weight: 700;
  height: 41rpx;
  left: 50%;
  line-height: 41rpx;
  position: absolute;
  text-align: center;
  top: 9rpx;
  transform: translate(-50%);
  width: 41rpx;
}
