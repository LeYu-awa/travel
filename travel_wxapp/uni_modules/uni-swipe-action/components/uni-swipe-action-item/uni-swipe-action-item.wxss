.uni-swipe {
  overflow: hidden;
  position: relative;
}
.uni-swipe_box {
  display: flex;
  flex-shrink: 0;
  position: relative;
}
.uni-swipe_text--center {
  cursor: grab;
  width: 100%;
}
.uni-swipe_button-group {
  bottom: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  position: absolute;
  top: 0;
}
.button-group--left {
  left: 0;
  transform: translate(-100%);
}
.button-group--right {
  right: 0;
  transform: translate(100%);
}
.uni-swipe_button {
  align-items: center;
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 0 40rpx;
}
.uni-swipe_button-text {
  flex-shrink: 0;
  font-size: 28rpx;
}
.ani {
  transition-duration: 0.3s;
  transition-property: transform;
  transition-timing-function: cubic-bezier(0.165, 0.84, 0.44, 1);
}
