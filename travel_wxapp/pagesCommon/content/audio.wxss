.box-crice {
  align-items: center;
  background: hsla(0, 0%, 100%, 0.9);
  border: 4rpx solid #eee;
  border-radius: 80rpx;
  bottom: 200rpx;
  display: flex;
  height: 96rpx;
  position: fixed;
  right: 26rpx;
  width: 300rpx;
}
.box-crice .false-crice {
  align-items: center;
  display: flex;
  margin-top: -6rpx;
}
.box-crice .box-time {
  font-family: OPPOSans;
  font-size: 28rpx;
  font-weight: 400;
  margin-left: 26rpx;
}
.collection {
  align-items: center;
  background: #343434;
  border-radius: 12rpx;
  bottom: 9%;
  display: flex;
  justify-content: space-between;
  left: 30rpx;
  padding: 28rpx 20rpx;
  position: fixed;
  width: 87%;
  z-index: 100000;
}
.collection .colon-flex {
  align-items: center;
  color: #fff;
  display: flex;
  font-size: 26rpx;
}
.collection .colon-flex .left {
  font-size: 24rpx;
  margin-left: 12rpx;
}
.collection .colon-flex .right {
  font-size: 24rpx;
  margin-right: 12rpx;
}
view {
  box-sizing: initial !important;
}
.header {
  background-color: initial;
  height: 180rpx;
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 91111;
}
.header .header-img {
  font-size: 42rpx;
  height: 40rpx;
  left: 26rpx;
  line-height: 40rpx;
  position: absolute;
  top: 100rpx;
}
.header .header-img .icon-a-20_fanhuianniu {
  font-size: 40rpx;
}
.audio .audio-flex {
  align-items: center;
  display: flex;
  flex-direction: column;
}
.audio .audio-flex .audio-image {
  border-radius: 16rpx;
  height: 450rpx;
  width: 450rpx;
}
.audio .audio-flex .audio-title {
  font-family: PingFang SC;
  font-size: 40rpx;
  font-weight: 500;
  line-height: 52rpx;
  margin-top: 40rpx;
  text-align: center;
  width: 642rpx;
}
.audio .audio-flex .audio-second {
  color: gray;
  font-family: OPPOSans;
  font-size: 28rpx;
  font-weight: 400;
  margin-top: 26rpx;
}
.audio .audio-flex .audio-bn {
  align-items: center;
  background-color: #000;
  background-image: url(https://dsplatweb.oss-cn-chengdu.aliyuncs.com/songzan/images/btnWhite.png);
  background-repeat: repeat;
  background-size: 80rpx 64rpx;
  border-radius: 14rpx;
  border-radius: 16rpx;
  color: #fff;
  display: flex;
  font-size: 28rpx;
  height: 96rpx;
  justify-content: center;
  margin-left: 30rpx;
  margin-top: 40rpx;
  width: 450rpx;
}
.audio .audio-flex .audio-bn .no-icon {
  margin-right: 14rpx;
}
.audio .audio-flex .audio-bn .no-title {
  font-family: PingFang SC;
  font-size: 32rpx;
  font-weight: 400;
}
.audio .audio-flex .but-right {
  align-items: center;
  display: flex;
  margin-left: -20rpx;
  margin-top: 40rpx;
}
.audio .audio-flex .but-right .but-con {
  align-items: flex-start;
  color: #000;
  display: flex;
  margin-left: 20rpx;
}
.audio .audio-flex .but-right .but-con .icon-a-12_tishi,
.audio .audio-flex .but-right .but-con .icon-a-20_shaixuan1,
.audio .audio-flex .but-right .but-con .icon-a-20_shoucang_weishoucang,
.audio .audio-flex .but-right .but-con .icon-a-20_shoucang_yishoucang {
  font-size: 40rpx;
}
.audio .audio-flex .but-right .but-con .but-share {
  background-color: initial;
  border: none;
}
.audio .audio-flex .but-right .but-con .but-share:after {
  border: none;
}
.audio .audio-flex .but-right .but-con .con-number {
  font-size: 26rpx;
}
.audio .audio-flex .but-right .but-con .con-number .number-left {
  color: gray;
  font-size: 26rpx;
}
.movableArea {
  bottom: 0;
  height: 100%;
  left: 0;
  pointer-events: none;
  position: fixed;
  top: 0;
  width: 100%;
}
.movableArea .movableView {
  height: 110rpx;
  pointer-events: auto;
  position: absolute;
  top: 280rpx;
  width: 120rpx;
}
.notification {
  background: #fdfdfd;
  border-radius: 8rpx;
  height: 170rpx;
  width: 122rpx;
}
.notification .ion-image {
  border-radius: 8rpx;
  height: 122rpx;
  width: 122rpx;
}
.notification .ioc-flex {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
  padding: 0 6rpx;
}
.notification .ioc-flex .icon-a-20_guanbi,
.notification .ioc-flex .icon-a-20_zanting {
  color: #000;
  font-size: 28rpx;
  font-weight: 600;
}
.rich {
  margin-left: 20rpx;
  margin-top: 40rpx;
  width: 95%;
}
