.hairline,
.hairline--bottom,
.hairline--left,
.hairline--right,
.hairline--surround,
.hairline--top,
.hairline--top-bottom {
  --hairline-color: #ccc;
  --hairline-rounded: 0;
  position: relative;
}
.hairline--bottom:after,
.hairline--left:after,
.hairline--right:after,
.hairline--surround:after,
.hairline--top-bottom:after,
.hairline--top:after,
.hairline:after {
  border-color: var(--hairline-color);
  border-radius: var(--hairline-rounded);
  border-style: solid;
  border-width: 0;
  bottom: -50%;
  content: "";
  left: -50%;
  pointer-events: none;
  position: absolute;
  right: -50%;
  top: -50%;
  transform: scale(0.5);
  transform-origin: center;
}
.hairline--top:after {
  border-top-width: 1px;
}
.hairline--left:after {
  border-left-width: 1px;
}
.hairline--right:after {
  border-right-width: 1px;
}
.hairline--bottom:after {
  border-bottom-width: 1px;
}
.hairline--top-bottom:after,
.hairline-unset--top-bottom:after {
  border-width: 1px 0;
}
.hairline--surround:after {
  border-width: 1px;
}
.safe-area {
