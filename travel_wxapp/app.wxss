  }
  40% {
    animation-timing-function: ease-out;
    transform: perspective(800rpx) scaleX(1) translateZ(300rpx) rotateY(-190deg);
  }
  50% {
    animation-timing-function: ease-in;
    transform: perspective(800rpx) scaleX(1) translateZ(300rpx) rotateY(-170deg);
  }
  80% {
