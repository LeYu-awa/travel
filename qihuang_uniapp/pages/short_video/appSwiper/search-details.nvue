					<text class="tName" :data-index="index" :class="currentNav==item.id?'on':''"
						@click.stop="navTap(item,index)">{{item.cate_name}}</text>
				</view>
			</view> -->
			<view class="noVideo acea-row row-center-wrapper" v-if="!dataList.length && !loadVideo">
				<view>
					<image :src="imgHost+'/static/no-video.png'" class="pictrue"></image>
					<text class="tips">暂无短视频内容哦~</text>
				</view>
			</view>

			<!-- 使用 swiper 组件实现左右滑动 -->
			<!-- <swiper :current="currentSwiperIndex" @change="swiperChange"
			:style="'width: '+ windowWidth +'px; height: '+ boxStyle.height +'px;'"> -->
			<!-- 这里可以添加多个 swiper-item 来实现多页面滑动 -->
			<!-- <swiper-item v-for="(menu,index) in menuList" :key="index" :item-id="`${menu.id}`"> -->
			<!-- 原有的主要内容放到这里 -->
			<view v-if="!dataList.length && !loadVideo" class="noVideo acea-row row-center-wrapper">
